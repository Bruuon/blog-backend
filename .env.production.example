# Production environment variables for Vercel deployment
# Copy this file to .env.production and fill in real values,
# or set these directly in the Vercel dashboard (Settings > Environment Variables)

# MongoDB Atlas connection string (not localhost!)
# Example: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/blog?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri

# Strong random secret for JWT signing
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret

# PORT is not needed on Vercel — the platform assigns it automatically
